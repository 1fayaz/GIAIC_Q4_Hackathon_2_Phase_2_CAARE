# Frontend environment variables — copy to frontend/.env.local and fill in real values.

# URL of the deployed FastAPI backend.
# Local: http://localhost:8000
# Production: https://your-backend.onrender.com
NEXT_PUBLIC_API_URL=https://fan007ali-todo-app-phase3-q4-giaic.hf.space

# Better Auth — server-side only, never expose with NEXT_PUBLIC_ prefix.
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-min-32-chars

# Public URL of the frontend itself.
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
BETTER_AUTH_URL=http://localhost:3000
