# Backend environment variables — copy to backend/.env and fill in real values.

# Database (Neon serverless Postgres). Must use the asyncpg driver.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DATABASE?ssl=require

# CORS — JSON array of allowed frontend origins.
# Local dev: ["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://localhost:3003"]
# Production: ["https://your-app.vercel.app"]
CORS_ORIGINS=["http://localhost:3000"]

# Logging
LOG_LEVEL=INFO

# Deployment environment. Use "production" when deployed (HTTPS).
# Controls cookie Secure / SameSite so cross-site auth works in prod.
ENVIRONMENT=development

# JWT — generate strong random secrets, e.g. `openssl rand -base64 32`
JWT_SECRET=change-me-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600
